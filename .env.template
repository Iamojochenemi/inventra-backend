# =============================================================================
#  INVENTRA — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.template .env
# =============================================================================


# ------------------------------
#  DJANGO CORE
# ------------------------------
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------
#  DATABASE (PostgreSQL)
# ------------------------------
DB_NAME=inventra_db
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# ------------------------------
#  REDIS (Celery broker + Cache)
# ------------------------------
REDIS_CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ------------------------------
#  LOG LEVELS
# ------------------------------
# Controls verbosity of the root logger.
LOG_LEVEL=INFO

# Controls verbosity of Django framework loggers (django.*).
DJANGO_LOG_LEVEL=INFO

# Controls verbosity of application loggers (apps.*).
APP_LOG_LEVEL=INFO

# ------------------------------
#  EMAIL (SMTP)
# ------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@inventra.com

# URL where the frontend is served (used in email links).
FRONTEND_URL=http://localhost:3000

# ------------------------------
#  PAYSTACK (Payment Gateway)
# ------------------------------
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# ------------------------------
#  SENTRY (Error Tracking)
# ------------------------------
SENTRY_DSN=
